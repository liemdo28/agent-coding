{
  "name": "agent-coding",
  "version": "2.0.0",
  "description": "Persistent Autonomous Engineering Civilization Infrastructure",
  "type": "module",
  "bin": {
    "aos": "./src/cli/aos.js",
    "local-agent": "./bin/local-agent.js",
    "kb": "./bin/kb.js"
  },
  "scripts": {
    "start": "node bin/local-agent.js",
    "dev": "node bin/local-agent.js",
    "build": "node scripts/build-check.js",
    "kernel:start": "npx tsx apps/api/src/index.ts",
    "kernel:dev": "npx tsx watch apps/api/src/index.ts",
    "telegram:start": "npx tsx apps/telegram-gateway/src/index.ts",
    "docker:up": "docker-compose -f infrastructure/docker/docker-compose.yml up -d",
    "docker:down": "docker-compose -f infrastructure/docker/docker-compose.yml down",
    "bootstrap:v2": "bash scripts/bootstrap-v2.sh",
    "corp:simulate": "node bin/super-agent-corp.js",
    "lint": "node scripts/lint-check.js",
    "stress": "bash scripts/stress-test.sh",
    "setup:production": "bash scripts/production-setup.sh",
    "test": "node --test tests/smoke.test.js tests/modules.test.js",
    "test:aos": "node --test tests/aos-runtime.test.js",
    "test:integration": "node --test tests/integration/cli.test.js",
    "ui:build": "npm --prefix local-agent/ui/frontend install --silent && npm --prefix local-agent/ui/frontend run build",
    "ui:server": "node local-agent/ui/backend/server.js",
    "ui": "npm run ui:build && npm run ui:server",
    "ui:dev:frontend": "npm --prefix local-agent/ui/frontend run dev",
    "kb:ingest": "node scripts/kb-ingest.js",
    "kb:ingest:mdn": "node kb/ingest-mdn.js",
    "kb:generate-stats": "node kb/generate-stats.js",
    "kb:package": "node scripts/kb-package.js",
    "kb:install": "node scripts/kb-install.js",
    "kb:query": "node bin/kb.js query",
    "kb:stats": "node bin/kb.js stats",
    "kb:seed": "node bin/kb.js seed",
    "eval:all": "node eval/runner.js --all",
    "eval:humaneval": "node eval/runner.js --benchmark humaneval",
    "eval:mbpp": "node eval/runner.js --benchmark mbpp",
    "eval:swelite": "node eval/runner.js --benchmark swe-bench-lite",
    "eval:multipl": "node eval/runner.js --benchmark multipl-e",
    "eval:ds1000": "node eval/runner.js --benchmark ds-1000",
    "eval:codecontests": "node eval/runner.js --benchmark codecontests",
    "eval:vendor": "node eval/vendor/humaneval-vendor.js && node eval/vendor/mbpp-vendor.js",
    "eval:scoreboard": "node eval/scoreboard.js",
    "eval:golden": "node eval/golden-corpus/runner.js",
    "eval:quick": "node eval/runner.js --all --limit 5"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "diff": "^5.2.0",
    "express": "^4.22.2",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.1",
    "ora": "^8.0.1",
    "bullmq": "^5.0.0",
    "dotenv": "^16.4.0",
    "fastify": "^4.26.0",
    "ioredis": "^5.3.0",
    "nanoid": "^5.0.0",
    "pg": "^8.11.0",
    "pino": "^8.19.0",
    "socket.io": "^4.7.0",
    "zod": "^3.22.0",
    "@qdrant/js-client-rest": "^1.8.0",
    "openai": "^4.28.0",
    "telegraf": "^4.16.0",
    "eventemitter3": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}