{
  "name": "local-agent",
  "version": "1.0.0",
  "description": "Fully local/offline AI Coding Agent",
  "type": "module",
  "bin": {
    "local-agent": "./bin/local-agent.js",
    "accounting":  "./accounting-engine/bin/accounting.js",
    "kb":          "./bin/kb.js"
  },
  "scripts": {
    "start":            "node bin/local-agent.js",
    "dev":              "node bin/local-agent.js",
    "build":            "node scripts/build-check.js",
    "lint":             "node scripts/lint-check.js",
    "test":             "node --test tests/smoke.test.js tests/modules.test.js",
    "test:integration": "node --test tests/integration/cli.test.js",
    "ui:server":        "node local-agent/ui/backend/server.js",
    "accounting:api":   "node accounting-engine/api/server.js",
    "accounting:stress":  "cd accounting-engine && node --experimental-vm-modules node_modules/.bin/jest tests/stress --runInBand",
    "accounting:verify":  "node accounting-engine/bin/accounting.js verify-ledger",
    "accounting:cert":    "node accounting-engine/tests/stress/live-24h-certification.js --duration=2m",
    "kb:ingest":          "node scripts/kb-ingest.js",
    "kb:package":         "node scripts/kb-package.js",
    "kb:install":         "node scripts/kb-install.js",
    "kb:query":           "node bin/kb.js query",
    "kb:stats":           "node bin/kb.js stats",
    "kb:seed":            "node bin/kb.js seed"
  },
  "dependencies": {
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.3.0",
    "chokidar": "^3.6.0",
    "commander": "^12.0.0",
    "cors": "^2.8.6",
    "diff": "^5.2.0",
    "express": "^4.22.2",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.1",
    "ora": "^8.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
