{
  "name": "accounting-engine",
  "version": "1.0.0",
  "description": "Local offline accounting DB system with WAL SQLite, hash-chain audit ledger, and resource monitoring",
  "type": "module",
  "bin": {
    "accounting": "./bin/accounting.js"
  },
  "scripts": {
    "start":      "node bin/accounting.js",
    "api":        "node api/server.js",
    "test":       "node --experimental-vm-modules node_modules/.bin/jest --runInBand",
    "test:unit":  "node --experimental-vm-modules node_modules/.bin/jest tests/unit --runInBand",
    "test:integration": "node --experimental-vm-modules node_modules/.bin/jest tests/integration --runInBand",
    "test:security":    "node --experimental-vm-modules node_modules/.bin/jest tests/security --runInBand",
    "test:stress":      "node tests/stress/seed-stress.js"
  },
  "dependencies": {
    "better-sqlite3": "^9.4.3",
    "chalk":          "^5.3.0",
    "commander":      "^12.0.0",
    "express":        "^4.18.2",
    "cors":           "^2.8.5",
    "ora":            "^8.0.1"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  }
}
